Form Dict: {'doc': '{"name":"Support Technician Print Formate","creation":"2026-05-06 13:28:45.960805","modified":"2026-05-06 14:27:06.700080","modified_by":"Administrator","owner":"Administrator","docstatus":0,"idx":0,"print_format_for":"DocType","doc_type":"Support Technician","module":"service manage","default_print_language":"en","standard":"Yes","custom_format":1,"disabled":0,"pdf_generator":"wkhtmltopdf","print_format_type":"Jinja","raw_printing":0,"html":"{%- set doc = doc -%}\\n{%- set tech_name = \\"\\" -%}\\n{%- if doc.technician_details_table %}\\n  {%- set tech_name = doc.technician_details_table[0].technician_name or \\"\\" -%}\\n{%- endif %}\\n{%- if not tech_name %}\\n  {%- set tech_doc = frappe.get_doc(\\"Technician\\", doc.assigned_technician) if doc.assigned_technician else none -%}\\n  {%- if tech_doc %}\\n    {%- set tech_name = tech_doc.technician_name or tech_doc.full_name or tech_doc.name or \\"\\" -%}\\n  {%- endif %}\\n{%- endif %}\\n\\n<!DOCTYPE html>\\n<html lang=\\"en\\">\\n<head>\\n<meta charset=\\"UTF-8\\"/>\\n<style>\\n  @import url(\'https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap\');\\n\\n  * { box-sizing: border-box; margin: 0; padding: 0; }\\n\\n  body {\\n    font-family: \'IBM Plex Sans\', sans-serif;\\n    font-size: 11px;\\n    color: #1a1a2e;\\n    background: #fff;\\n    padding: 28px 36px;\\n  }\\n\\n  .header {\\n    display: flex;\\n    justify-content: space-between;\\n    align-items: flex-start;\\n    border-bottom: 3px solid #1a1a2e;\\n    padding-bottom: 14px;\\n    margin-bottom: 20px;\\n  }\\n  .header-left h1 {\\n    font-size: 22px;\\n    font-weight: 700;\\n    letter-spacing: -0.5px;\\n    text-transform: uppercase;\\n  }\\n  .header-left p {\\n    font-size: 10px;\\n    color: #555;\\n    margin-top: 2px;\\n    font-family: \'IBM Plex Mono\', monospace;\\n  }\\n  .header-right { text-align: right; }\\n\\n  .badge {\\n    display: inline-block;\\n    padding: 4px 12px;\\n    border-radius: 20px;\\n    font-size: 10px;\\n    font-weight: 700;\\n    letter-spacing: 0.8px;\\n    text-transform: uppercase;\\n  }\\n  .badge-pending   { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }\\n  .badge-working   { background: #cce5ff; color: #004085; border: 1px solid #007bff; }\\n  .badge-completed { background: #d4edda; color: #155724; border: 1px solid #28a745; }\\n  .badge-cancelled { background: #f8d7da; color: #721c24; border: 1px solid #dc3545; }\\n\\n  .meta-grid {\\n    display: grid;\\n    grid-template-columns: repeat(3, 1fr);\\n    gap: 10px 20px;\\n    background: #f4f6fb;\\n    border: 1px solid #dde3ef;\\n    border-radius: 6px;\\n    padding: 14px 18px;\\n    margin-bottom: 22px;\\n  }\\n  .meta-item label {\\n    display: block;\\n    font-size: 9px;\\n    font-weight: 700;\\n    letter-spacing: 0.8px;\\n    text-transform: uppercase;\\n    color: #888;\\n    margin-bottom: 3px;\\n  }\\n  .meta-item span {\\n    font-size: 11px;\\n    font-weight: 600;\\n    color: #1a1a2e;\\n  }\\n\\n  .section-title {\\n    font-size: 10px;\\n    font-weight: 700;\\n    letter-spacing: 1px;\\n    text-transform: uppercase;\\n    color: #555;\\n    border-left: 3px solid #1a1a2e;\\n    padding-left: 8px;\\n    margin-bottom: 10px;\\n  }\\n\\n  .tech-card {\\n    display: flex;\\n    gap: 40px;\\n    background: #fff;\\n    border: 1px solid #dde3ef;\\n    border-radius: 6px;\\n    padding: 12px 18px;\\n    margin-bottom: 22px;\\n    align-items: center;\\n  }\\n  .tech-card .field label {\\n    font-size: 9px;\\n    font-weight: 700;\\n    letter-spacing: 0.7px;\\n    text-transform: uppercase;\\n    color: #888;\\n    display: block;\\n    margin-bottom: 3px;\\n  }\\n  .tech-card .field span {\\n    font-size: 12px;\\n    font-weight: 600;\\n    color: #1a1a2e;\\n  }\\n\\n  table.service-table {\\n    width: 100%;\\n    border-collapse: collapse;\\n    margin-bottom: 16px;\\n    font-size: 10.