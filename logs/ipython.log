2026-05-03 11:03:39,330 INFO ipython import frappe
2026-05-03 11:03:39,331 INFO ipython from frappe.utils import get_datetime
2026-05-03 11:03:39,331 INFO ipython def backfill_totals():
    # detect total field
    possible_totals = ['custom_total_time_taken','custom_total_time','total_time']
    cols = frappe.db.get_table_columns('Support Technician')
    total_field = next((f for f in possible_totals if f in cols), None)
    print('Detected total field:', total_field)
2026-05-03 11:03:39,331 INFO ipython     rows = frappe.db.sql("SELECT name, custom_start_time, custom_end_time FROM `tabSupport Technician` WHERE custom_start_time IS NOT NULL AND custom_end_time IS NOT NULL", as_dict=True)
2026-05-03 11:03:39,331 INFO ipython     updated = 0
2026-05-03 11:03:39,331 INFO ipython     for r in rows:
        try:
            s = get_datetime(r['custom_start_time'])
            e = get_datetime(r['custom_end_time'])
            secs = (e - s).total_seconds()
            if secs is None or secs < 0:
                continue
            hours = round(secs/3600,6)
            if total_field:
                frappe.db.set_value('Support Technician', r['name'], total_field, hours, update_modified=False)
            else:
                frappe.db.set_value('Support Technician', r['name'], 'total_time', hours, update_modified=False)
            updated += 1
        except Exception as e:
            print('error', r['name'], e)
    print('Backfilled', updated, 'rows')
2026-05-03 11:03:39,331 INFO ipython backfill_totals()
2026-05-03 11:03:39,332 INFO ipython === session end ===
2026-05-03 11:03:59,197 INFO ipython === bench console session ===
2026-05-03 11:03:59,198 INFO ipython import frappe
2026-05-03 11:03:59,198 INFO ipython from frappe.utils import get_datetime
2026-05-03 11:03:59,198 INFO ipython cols = frappe.db.get_table_columns('Support Technician')
2026-05-03 11:03:59,198 INFO ipython possible_totals = ['custom_total_time_taken','custom_total_time','total_time']
2026-05-03 11:03:59,198 INFO ipython total_field = next((f for f in possible_totals if f in cols), None)
2026-05-03 11:03:59,198 INFO ipython print('Detected total field:', total_field)
2026-05-03 11:03:59,198 INFO ipython rows = frappe.db.sql("SELECT name, custom_start_time, custom_end_time, {} FROM `tabSupport Technician` WHERE custom_start_time IS NOT NULL AND custom_end_time IS NOT NULL".format(total_field if total_field else 'NULL'), as_dict=True)
2026-05-03 11:03:59,199 INFO ipython updated = 0
2026-05-03 11:03:59,199 INFO ipython for r in rows:
    name = r['name']
    cs = r.get('custom_start_time')
    ce = r.get('custom_end_time')
    cur_total = r.get(total_field) if total_field else None
    try:
        s = get_datetime(cs)
        e = get_datetime(ce)
        secs = (e - s).total_seconds()
        if secs is None or secs < 0:
            print('skip negative or none', name)
            continue
        hours = round(secs/3600,6)
        if total_field:
            if not cur_total or float(cur_total)==0:
                frappe.db.set_value('Support Technician', name, total_field, hours, update_modified=False)
                updated += 1
                print('updated', name, hours)
            else:
                print('exists', name, cur_total)
        else:
            frappe.db.set_value('Support Technician', name, 'total_time', hours, update_modified=False)
            updated += 1
            print('updated fallback', name, hours)
    except Exception as e:
        print('error', name, e)
print('Backfilled', updated, 'rows')
2026-05-03 11:03:59,199 INFO ipython === session end ===
